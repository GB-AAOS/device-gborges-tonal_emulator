android_app {
    name: "ProximityMonitorApp",
    srcs: ["src/**/*.kt"],
    resource_dirs: ["res"],
    manifest: "AndroidManifest.xml",
    
    sdk_version: "current",
    
    product_specific: true,
    
    certificate: "platform",

    static_libs: [
        "kotlin-stdlib",
    ],
    
    dex_preopt: {
        enabled: true,
    },
}